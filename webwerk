show_status() {
    log_info "Webwerk WordPress Management Suite Status"
    echo "----------------------------------------"
    echo "Script Directory: $SCRIPT_DIR"
    echo "Configuration File: ${SCRIPT_DIR}/.env $(if [[ -f "${SCRIPT_DIR}/.env" ]]; then echo "(✓)"; else echo "(✗)"; fi)"
    echo "License Keys: ~/.keys $(if [[ -f "$HOME/.keys" ]]; then echo "(✓)"; else echo "(✗)"; fi)"
    echo "Database Host: ${DB_HOST:-'not configured'}"
    echo "Database User: ${DB_USER:-'not configured'}"
    echo "WP-CLI: ${WP_CLI_PATH:-'not configured'} $(if command -v "${WP_CLI_PATH:-wp}" &> /dev/null; then echo "(✓)"; else echo "(✗)"; fi)"
    echo "Git User: ${GIT_USER:-'not configured'}"
    echo "Log File: $LOG_FILE"
    echo ""
    
    # Check script files
    echo "Script Files:"
    local scripts=(
        "scripts/install/wplocalinstall.sh"
        "scripts/install/wpfunctionsinstall.sh"
        "scripts/update/wpupdate.sh"
        "scripts/mod/wpmod.sh"
        "scripts/utils/wphelpfunctions.sh"
    )
    
    for script in "${scripts[@]}"; do
        if [[ -f "${SCRIPT_DIR}/${script}" ]]; then
            echo "  ✓ $script"
        else
            echo "  ✗ $script (missing)"
        fi
    done
}

# Render install log lines as a single-line phase progress bar + current activity.
# Reads piped install output; errors/warnings are surfaced on their own line.
render_install_progress() {
    shopt -s nocasematch   # phase keys match log lines case-insensitively
    local phase_keys=(
        "requirements validated"
        "database connection validated"
        "Downloading WordPress"
        "WordPress core downloaded"
        "Creating wp-config"
        "Database reset"
        "Installing WordPress"
        "Cloning repository"
        "Activating all"
        "Activating theme"
        "license keys"
        "installation completed"
    )
    local total=${#phase_keys[@]} cur=0 line msg pct fill bar i j width out
    while IFS= read -r line; do
        line="$(printf '%s' "$line" | sed 's/\x1b\[[0-9;]*m//g')"
        # surface errors/warnings on their own line (both LEVEL: and [LEVEL] formats)
        if [[ "$line" == *ERROR:* || "$line" == *"ERROR]"* ]]; then printf '\r\033[K\033[31m%s\033[0m\n' "$line"; continue; fi
        if [[ "$line" == *WARNING:* || "$line" == *"WARNING]"* ]]; then printf '\r\033[K\033[33m%s\033[0m\n' "$line"; continue; fi
        [[ "$line" == *INFO:* || "$line" == *"INFO]"* || "$line" == *SUCCESS:* || "$line" == *"SUCCESS]"* ]] || continue
        # strip "[timestamp] [LEVEL] " or "[timestamp] LEVEL: " prefix, keep the message
        msg="$(printf '%s' "$line" | sed -E 's/^\[[^]]*\] (\[(INFO|SUCCESS)\]|(INFO|SUCCESS):) *//')"
        # advance to the matched phase (tolerant of skipped/missing phases, never goes back)
        for (( j=0; j<total; j++ )); do
            if [[ "$line" == *"${phase_keys[j]}"* ]]; then (( j+1 > cur )) && cur=$((j+1)); break; fi
        done
        pct=$(( cur * 100 / total ))
        fill=$(( pct * 20 / 100 ))
        bar=""
        for (( i=0; i<20; i++ )); do (( i < fill )) && bar+="#" || bar+="-"; done
        width=$(( ${COLUMNS:-119} - 1 ))
        out="$(printf '[%s] %3d%% (%d/%d) | %s' "$bar" "$pct" "$cur" "$total" "$msg")"
        printf '\r%.*s\033[K' "$width" "$out"
    done
    printf '\n'
}

# Run the installer. On a terminal, show the single-line progress bar by default;
# when piped/redirected (e.g. the `repo` batch) or with --verbose/--debug, pass logs through.
run_install() {
    local installer="${SCRIPT_DIR}/scripts/install/wplocalinstall.sh"
    if [[ ! -f "$installer" ]]; then
        log_error "Installation script not found: $installer"
        exit 1
    fi
    local a verbose="${WEBWERK_INSTALL_VERBOSE:-0}" batch="" args=() rc
    for a in "$@"; do
        case "$a" in
            -v|--verbose) verbose=1 ;;
            --debug)      verbose=1; args+=("$a") ;;
            -A)           batch=auto ;;
            -a)           batch=ask ;;
            *)            args+=("$a") ;;
        esac
    done
    if [[ -n "$batch" ]]; then
        run_install_batch "$batch" "$verbose" "${args[@]}"
        exit $?
    fi
    set +e   # capture the installer's exit code ourselves (dispatcher runs under set -e)
    if [[ -t 1 && "$verbose" != "1" ]]; then
        bash "$installer" "${args[@]}" 2>&1 | render_install_progress
        rc=${PIPESTATUS[0]}
    else
        bash "$installer" "${args[@]}"
        rc=$?
    fi
    exit "$rc"
}

# Batch install into each empty immediate subdirectory of the current dir.
# $1 = ask|auto, $2 = verbose (0/1), rest = installer args (incl. mode).
# Non-empty dirs are skipped with a warning; the dir name is the site/repo name.
run_install_batch() {
    local prompt="$1" verbose="$2"; shift 2
    local installer="${SCRIPT_DIR}/scripts/install/wplocalinstall.sh"
    export WEBWERK_BATCH=1   # keep per-site installs non-interactive (e.g. theme prompt)
    local d ans rc ok=0 skipped=0 failed=0 idx=0 dirs=()
    for d in */; do [[ -d "$d" ]] && dirs+=("${d%/}"); done
    local total=${#dirs[@]}
    if (( total == 0 )); then
        log_warning "No subdirectories to install in $(pwd)"
        return 0
    fi
    log_info "Batch install: $total subdirectories under $(pwd)"
    for d in "${dirs[@]}"; do
        (( ++idx ))
        if [[ -n "$(ls -A "$d" 2>/dev/null)" ]]; then
            log_warning "[$idx/$total] $d — not empty, skipping"
            (( ++skipped )); continue
        fi
        if [[ "$prompt" == "ask" ]]; then
            read -rsn1 -p "[$idx/$total] Install $d? [y/n/x] " ans; echo
            case "${ans,,}" in
                y) ;;
                x) log_info "Stopped at $d"; break ;;
                *) (( ++skipped )); continue ;;
            esac
        fi
        echo -e "\033[36m=== [$idx/$total] $d ===\033[0m"
        set +e
        if [[ -t 1 && "$verbose" != "1" ]]; then
            ( cd "$d" && bash "$installer" "$@" ) 2>&1 | render_install_progress
            rc=${PIPESTATUS[0]}
        else
            ( cd "$d" && bash "$installer" "$@" )
            rc=$?
        fi
        set -e
        if (( rc == 0 )); then (( ++ok )); else (( ++failed )); log_warning "[$idx/$total] $d failed (rc=$rc)"; fi
    done
    echo -e "\033[32mBatch done: ${ok} ok, ${skipped} skipped, ${failed} failed\033[0m"
    (( failed == 0 ))
}

#===============================================================================
# MAIN EXECUTION
#===============================================================================

# Resolve an abbreviation to a canonical word by unique-prefix match.
# Usage: resolve_word <token> <canonical>...
# Echoes the canonical word on an exact or unambiguous prefix match,
# otherwise echoes the token unchanged (so callers can reject it as before).
resolve_word() {
    local token="$1"; shift
    local w match="" count=0
    for w in "$@"; do
        [[ "$w" == "$token" ]] && { echo "$w"; return 0; }   # exact match wins
    done
    for w in "$@"; do
        [[ "$w" == "$token"* ]] && { match="$w"; count=$((count + 1)); }
    done
    if [[ $count -eq 1 ]]; then echo "$match"; else echo "$token"; fi
}

# Remove the DDEV containers/config in the current directory.
ddev_remove() {
    log_info "Removing DDEV containers and configuration"
    if [[ ! -f ".ddev/config.yaml" ]]; then
        log_warning "No DDEV configuration found in current directory"
        exit 0
    fi
    log_info "Stopping DDEV containers..."
    ddev stop
    log_info "Removing DDEV containers..."
    ddev delete -O
    log_success "DDEV containers removed successfully"
}

# Run the updater against the DDEV site in the current directory.
ddev_update() {
    log_info "Running WordPress update (mode: ddev)"
    if ! ddev status >/dev/null 2>&1; then
        log_error "DDEV is not running. Please start DDEV first with 'ddev start'"
        exit 1
    fi
    export WP_CLI_PATH="ddev wp"
    export WORDPRESS_BASE_DIR=""
    if [[ ! -f "${SCRIPT_DIR}/scripts/update/wpupdate.sh" ]]; then
        log_error "Update script not found: ${SCRIPT_DIR}/scripts/update/wpupdate.sh"
        exit 1
    fi
    exec bash "${SCRIPT_DIR}/scripts/update/wpupdate.sh" --sites . "$@"
}

# Remove host-side WordPress site(s): drop each site's database, then wipe the
# directory contents (the now-empty dir is kept). DESTRUCTIVE.
#   (default)   current dir, which must be a WordPress install
#   -s a,b      those subdirs of the base dir
#   -a / -A     every WP site under the base dir  (-a prompts each, -A auto)
#   -y          skip the per-site confirmation
remove_local() {
    local base="${WORDPRESS_BASE_DIR:-.}"
    local target="cwd" assume_yes=0 sites_csv=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -s|--sites)          sites_csv="${2:-}"; shift 2 ;;
            -s=*|--sites=*)      sites_csv="${1#*=}"; shift ;;
            -a|--all-sites)      target="all"; shift ;;
            -A|--all-sites-auto) target="all"; assume_yes=1; shift ;;
            -y|--yes)            assume_yes=1; shift ;;
            *) log_error "remove local: unknown option '$1'"; exit 1 ;;
        esac
    done

    local dirs=() s cfg
    if [[ -n "$sites_csv" ]]; then
        local IFS=','
        for s in $sites_csv; do dirs+=("$base/$s"); done
    elif [[ "$target" == "all" ]]; then
        while IFS= read -r cfg; do dirs+=("$(dirname "$cfg")"); done \
            < <(find "$base" -maxdepth 2 -name wp-config.php 2>/dev/null | sort)
        if [[ ${#dirs[@]} -eq 0 ]]; then
            log_warning "No WordPress sites found under $base"; exit 0
        fi
    else
        dirs+=(".")
    fi

    # the dispatcher logs into ${PWD}/webwerk.log; remember that dir so we can
    # drop the log we recreate if we end up wiping the dir it lives in
    local log_dir wiped_log_dir=0
    log_dir="$(cd "$(dirname "$LOG_FILE")" 2>/dev/null && pwd)"

    local dir abs dbname reply removed=0 skipped=0
    for dir in "${dirs[@]}"; do
        if [[ ! -f "$dir/wp-config.php" ]] \
           || ! "${WP_CLI_PATH}" core is-installed --path="$dir" >/dev/null 2>&1; then
            log_warning "Not a WordPress install, skipping: $dir"
            skipped=$((skipped + 1)); continue
        fi
        abs="$(cd "$dir" 2>/dev/null && pwd)"
        case "$abs" in
            "" | "/" | "$HOME")
                log_error "Refusing to delete protected path: ${abs:-$dir}"
                skipped=$((skipped + 1)); continue ;;
        esac
        dbname="$("${WP_CLI_PATH}" config get DB_NAME --path="$dir" 2>/dev/null || echo '?')"

        if [[ "$assume_yes" -ne 1 ]]; then
            log_warning "About to DROP database '$dbname' and delete all files in:"
            log_warning "  $abs"
            read -rp "Remove this site? [y/N] " reply
            if [[ ! "$reply" =~ ^[Yy]$ ]]; then
                log_info "Skipped: $abs"; skipped=$((skipped + 1)); continue
            fi
        fi

        log_info "Dropping database '$dbname'"
        "${WP_CLI_PATH}" db drop --yes --path="$dir" \
            || log_warning "Could not drop database '$dbname' (continuing with file deletion)"
        log_info "Deleting site files in $abs"
        find "$abs" -mindepth 1 -maxdepth 1 -exec rm -rf {} +
        [[ -n "$log_dir" && "$abs" == "$log_dir" ]] && wiped_log_dir=1
        log_success "Removed site: $abs"
        removed=$((removed + 1))
    done
    log_info "Remove done: $removed removed, $skipped skipped"
    # if our own log got recreated inside a wiped dir, remove it last (nothing logs after)
    [[ "$wiped_log_dir" -eq 1 ]] && rm -f "$LOG_FILE"
}

main() {
    local command="${1:-}"

    # Quiet mode (-V/--progress): keep dispatcher INFO output out of the terminal
    local arg
    for arg in "$@"; do
        if [[ "$arg" == "--progress" || "$arg" =~ ^-[a-zA-Z]*V ]]; then
            export WEBWERK_QUIET=1
        fi
    done

    # Accept unambiguous abbreviations for the top-level command
    # (i->install, u->update, m->mod, r->remove, s->status, d->ddev)
    if [[ -n "$command" && "$command" != -* ]]; then
        command="$(resolve_word "$command" install update mod remove status ddev)"
    fi

    # Handle special cases before loading configuration
    case "$command" in
        "" | "--help" | "-h")
            show_help
            exit 0
            ;;
        "status")
            # Load config for status display
            load_environment
            load_license_keys
            show_status
            exit 0
            ;;
    esac

    # Pass -h/--help directly to subcommand scripts, bypassing config loading
    local help_requested=false
    for arg in "${@:2}"; do
        if [[ "$arg" == "-h" || "$arg" == "--help" ]]; then
            help_requested=true
            break
        fi
    done
    if [[ "$help_requested" == true ]]; then
        case "$command" in
            "update")
                exec bash "${SCRIPT_DIR}/scripts/update/wpupdate.sh" --help ;;
            "mod")
                exec bash "${SCRIPT_DIR}/scripts/mod/wpmod.sh" --help ;;
            "install")
                exec bash "${SCRIPT_DIR}/scripts/install/wplocalinstall.sh" --help ;;
            "ddev")
                case "$(resolve_word "${2:-}" install remove mod update)" in
                    "update") exec bash "${SCRIPT_DIR}/scripts/update/wpupdate.sh" --help ;;
                    "mod")    exec bash "${SCRIPT_DIR}/scripts/mod/wpmod.sh" --help ;;
                    *)        exec bash "${SCRIPT_DIR}/scripts/install/wplocalinstall.sh" --help ;;
                esac
                ;;
        esac
    fi

    # Load all configuration
    log_info "Starting Webwerk WordPress Management Suite v2.0"
    load_environment
    load_license_keys
    validate_configuration "$command" "$@"
    load_helper_functions

    # Remove first argument (command/mode)
    shift

    # Execute command
    case "$command" in
        "install")
            # Syntax: webwerk install [local|bare|ddev]  (local is the default)
            local mode="local"
            case "${1:-}" in
                -*|"") ;;  # no mode word (flag or none): keep default, consume nothing
                *)
                    mode="$(resolve_word "$1" local bare ddev)"
                    case "$mode" in
                        local|bare|ddev) shift ;;  # a real mode word -> consume it
                        *)
                            log_error "Unknown install mode: '$1'. Use: local, bare, ddev"
                            exit 1
                            ;;
                    esac
                    ;;
            esac
            log_info "Executing WordPress installation (mode: $mode)"
            run_install "$mode" "$@"
            ;;
        "ddev")
            # DDEV mode - expect "install", "remove", "mod", or "update" next
            local subcommand
            subcommand="$(resolve_word "${1:-}" install remove mod update)"
            case "$subcommand" in
                "install")
                    shift  # Remove "install" from arguments
                    log_info "Executing WordPress installation (mode: ddev)"
                    run_install "ddev" "$@"
                    ;;
                "remove")
                    shift  # Remove "remove" from arguments
                    ddev_remove
                    ;;
                "mod")
                    shift  # Remove "mod" from arguments
                    log_info "Running WordPress modification (mode: ddev)"

                    # Check if DDEV is running
                    if ! ddev status >/dev/null 2>&1; then
                        log_error "DDEV is not running. Please start DDEV first with 'ddev start'"
                        exit 1
                    fi

                    # Set DDEV-specific environment variables
                    export WP_CLI_PATH="ddev wp"
                    export WORDPRESS_BASE_DIR="."

                    if [[ -f "${SCRIPT_DIR}/scripts/mod/wpmod.sh" ]]; then
                        bash "${SCRIPT_DIR}/scripts/mod/wpmod.sh" "$@"
                    else
                        log_error "Modification script not found: ${SCRIPT_DIR}/scripts/mod/wpmod.sh"
                        exit 1
                    fi
                    ;;
                "update")
                    shift  # Remove "update" from arguments
                    ddev_update "$@"
                    ;;
                *)
                    log_error "Expected 'install', 'remove', 'mod', or 'update' after 'ddev', got: ${subcommand:-nothing}"
                    log_error "Usage: $0 ddev [install|remove|mod|update] [OPTIONS]"
                    exit 1
                    ;;
            esac
            ;;
        "update")
            if [[ ! -f "${SCRIPT_DIR}/scripts/update/wpupdate.sh" ]]; then
                log_error "Update script not found: ${SCRIPT_DIR}/scripts/update/wpupdate.sh"
                exit 1
            fi
            # Optional leading mode: 'ddev' runs inside the container; 'local' is the default
            case "$(resolve_word "${1:-}" local ddev)" in
                "ddev")  shift; ddev_update "$@" ;;
                "local") shift ;;  # explicit local; fall through to normal handling
            esac
            local update_target="${1:-}"
            case "$update_target" in
                "core")
                    shift
                    log_info "Executing WordPress update (core only)"
                    exec bash "${SCRIPT_DIR}/scripts/update/wpupdate.sh" --skip-plugins "$@"
                    ;;
                "plugin")
                    shift
                    local plugin_name="${1:-}"
                    if [[ -z "$plugin_name" || "$plugin_name" == -* ]]; then
                        log_error "Usage: webwerk update plugin <name>[,name,...] [OPTIONS]"
                        exit 1
                    fi
                    shift
                    log_info "Executing WordPress update (plugin: $plugin_name)"
                    exec bash "${SCRIPT_DIR}/scripts/update/wpupdate.sh" --skip-core --only-plugins "$plugin_name" "$@"
                    ;;
                "plugins")
                    shift
                    log_info "Executing WordPress update (all plugins)"
                    exec bash "${SCRIPT_DIR}/scripts/update/wpupdate.sh" --skip-core "$@"
                    ;;
                "themes")
                    shift
                    log_info "Executing WordPress update (all themes)"
                    exec bash "${SCRIPT_DIR}/scripts/update/wpupdate.sh" --skip-core --skip-plugins --update-themes "$@"
                    ;;
                "theme")
                    shift
                    local theme_name="${1:-}"
                    if [[ -z "$theme_name" || "$theme_name" == -* ]]; then
                        log_error "Usage: webwerk update theme <name> [OPTIONS]"
                        exit 1
                    fi
                    shift
                    log_info "Executing WordPress update (theme: $theme_name)"
                    exec bash "${SCRIPT_DIR}/scripts/update/wpupdate.sh" --skip-core --skip-plugins --only-theme "$theme_name" "$@"
                    ;;
                ""|-*)
                    log_info "Executing WordPress update (core + plugins + themes)"
                    exec bash "${SCRIPT_DIR}/scripts/update/wpupdate.sh" --update-themes "$@"
                    ;;
                *)
                    log_error "Unknown update target: '$update_target'. Use: core, plugins, plugin <name>, themes, theme <name>, or omit for both."
                    exit 1
                    ;;
            esac
            ;;
        "mod")
            if [[ ! -f "${SCRIPT_DIR}/scripts/mod/wpmod.sh" ]]; then
                log_error "Modification script not found: ${SCRIPT_DIR}/scripts/mod/wpmod.sh"
                exit 1
            fi
            # Optional environment target: local (default) or ddev
            case "$(resolve_word "${1:-}" local ddev)" in
                "ddev")
                    shift
                    log_info "Executing WordPress modification (mode: ddev)"
                    if ! ddev status >/dev/null 2>&1; then
                        log_error "DDEV is not running. Please start DDEV first with 'ddev start'"
                        exit 1
                    fi
                    export WP_CLI_PATH="ddev wp"
                    export WORDPRESS_BASE_DIR="."
                    ;;
                "local")
                    shift
                    log_info "Executing WordPress modification (mode: local)"
                    ;;
                *)
                    log_info "Executing WordPress modification (mode: local)"
                    ;;
            esac
            exec bash "${SCRIPT_DIR}/scripts/mod/wpmod.sh" "$@"
            ;;
        "remove")
            # Syntax: webwerk remove local|ddev [OPTIONS]  (DESTRUCTIVE; mode required)
            case "$(resolve_word "${1:-}" local bare ddev)" in
                "ddev")  ddev_remove ;;
                "local") shift; remove_local "$@" ;;
                "bare")
                    log_error "No separate 'bare' removal; use: webwerk remove local"
                    exit 1
                    ;;
                *)
                    log_error "remove: specify a mode -> webwerk remove local|ddev"
                    exit 1
                    ;;
            esac
            ;;
        *)
            log_error "Unknown command: $command"
            log_error "Use '$0 --help' for usage information"
            exit 1
            ;;
    esac
}

# Execute main function with all arguments
main "$@"
