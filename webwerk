show_status() {
    log_info "Webwerk WordPress Management Suite Status"
    echo "----------------------------------------"
    echo "Script Directory: $SCRIPT_DIR"
    echo "Configuration File: ${SCRIPT_DIR}/.env $(if [[ -f "${SCRIPT_DIR}/.env" ]]; then echo "(✓)"; else echo "(✗)"; fi)"
    echo "License Keys: ~/.keys $(if [[ -f "$HOME/.keys" ]]; then echo "(✓)"; else echo "(✗)"; fi)"
    echo "Database Host: ${DB_HOST:-'not configured'}"
    echo "Database User: ${DB_USER:-'not configured'}"
    echo "WP-CLI: ${WP_CLI_PATH:-'not configured'} $(if command -v "${WP_CLI_PATH:-wp}" &> /dev/null; then echo "(✓)"; else echo "(✗)"; fi)"
    echo "Git User: ${GIT_USER:-'not configured'}"
    echo "Log File: $LOG_FILE"
    echo ""
    
    # Check script files
    echo "Script Files:"
    local scripts=(
        "scripts/install/wplocalinstall.sh"
        "scripts/install/wpfunctionsinstall.sh"
        "scripts/update/wpupdate.sh"
        "scripts/mod/wpmod.sh"
        "scripts/utils/wphelpfunctions.sh"
    )
    
    for script in "${scripts[@]}"; do
        if [[ -f "${SCRIPT_DIR}/${script}" ]]; then
            echo "  ✓ $script"
        else
            echo "  ✗ $script (missing)"
        fi
    done
}

# Render install log lines as a single-line phase progress bar + current activity.
# Reads piped install output; errors/warnings are surfaced on their own line.
render_install_progress() {
    shopt -s nocasematch   # phase keys match log lines case-insensitively
    local phase_keys=(
        "requirements validated"
        "database connection validated"
        "Downloading WordPress"
        "WordPress core downloaded"
        "Creating wp-config"
        "Database reset"
        "Installing WordPress"
        "Cloning repository"
        "Activating all"
        "license keys"
        "installation completed"
    )
    local total=${#phase_keys[@]} cur=0 line msg pct fill bar i j width out
    while IFS= read -r line; do
        line="$(printf '%s' "$line" | sed 's/\x1b\[[0-9;]*m//g')"
        # surface errors/warnings on their own line (both LEVEL: and [LEVEL] formats)
        if [[ "$line" == *ERROR:* || "$line" == *"ERROR]"* ]]; then printf '\r\033[K\033[31m%s\033[0m\n' "$line"; continue; fi
        if [[ "$line" == *WARNING:* || "$line" == *"WARNING]"* ]]; then printf '\r\033[K\033[33m%s\033[0m\n' "$line"; continue; fi
        [[ "$line" == *INFO:* || "$line" == *"INFO]"* || "$line" == *SUCCESS:* || "$line" == *"SUCCESS]"* ]] || continue
        # strip "[timestamp] [LEVEL] " or "[timestamp] LEVEL: " prefix, keep the message
        msg="$(printf '%s' "$line" | sed -E 's/^\[[^]]*\] (\[(INFO|SUCCESS)\]|(INFO|SUCCESS):) *//')"
        # advance to the matched phase (tolerant of skipped/missing phases, never goes back)
        for (( j=0; j<total; j++ )); do
            if [[ "$line" == *"${phase_keys[j]}"* ]]; then (( j+1 > cur )) && cur=$((j+1)); break; fi
        done
        pct=$(( cur * 100 / total ))
        fill=$(( pct * 20 / 100 ))
        bar=""
        for (( i=0; i<20; i++ )); do (( i < fill )) && bar+="#" || bar+="-"; done
        width=$(( ${COLUMNS:-119} - 1 ))
        out="$(printf '[%s] %3d%% (%d/%d) | %s' "$bar" "$pct" "$cur" "$total" "$msg")"
        printf '\r%.*s\033[K' "$width" "$out"
    done
    printf '\n'
}

# Run the installer. On a terminal, show the single-line progress bar by default;
# when piped/redirected (e.g. the `repo` batch) or with --verbose/--debug, pass logs through.
run_install() {
    local installer="${SCRIPT_DIR}/scripts/install/wplocalinstall.sh"
    if [[ ! -f "$installer" ]]; then
        log_error "Installation script not found: $installer"
        exit 1
    fi
    local a verbose="${WEBWERK_INSTALL_VERBOSE:-0}" args=() rc
    for a in "$@"; do
        case "$a" in
            -v|--verbose) verbose=1 ;;
            --debug)      verbose=1; args+=("$a") ;;
            *)         args+=("$a") ;;
        esac
    done
    set +e   # capture the installer's exit code ourselves (dispatcher runs under set -e)
    if [[ -t 1 && "$verbose" != "1" ]]; then
        bash "$installer" "${args[@]}" 2>&1 | render_install_progress
        rc=${PIPESTATUS[0]}
    else
        bash "$installer" "${args[@]}"
        rc=$?
    fi
    exit "$rc"
}

#===============================================================================
# MAIN EXECUTION
#===============================================================================

main() {
    local command="${1:-}"

    # Quiet mode (-V/--progress): keep dispatcher INFO output out of the terminal
    local arg
    for arg in "$@"; do
        if [[ "$arg" == "--progress" || "$arg" =~ ^-[a-zA-Z]*V ]]; then
            export WEBWERK_QUIET=1
        fi
    done

    # Handle special cases before loading configuration
    case "$command" in
        "" | "--help" | "-h")
            show_help
            exit 0
            ;;
        "status")
            # Load config for status display
            load_environment
            load_license_keys
            show_status
            exit 0
            ;;
    esac

    # Pass -h/--help directly to subcommand scripts, bypassing config loading
    local help_requested=false
    for arg in "${@:2}"; do
        if [[ "$arg" == "-h" || "$arg" == "--help" ]]; then
            help_requested=true
            break
        fi
    done
    if [[ "$help_requested" == true ]]; then
        case "$command" in
            "u" | "update")
                exec bash "${SCRIPT_DIR}/scripts/update/wpupdate.sh" --help ;;
            "mod")
                exec bash "${SCRIPT_DIR}/scripts/mod/wpmod.sh" --help ;;
            "install" | "full" | "minimal")
                exec bash "${SCRIPT_DIR}/scripts/install/wplocalinstall.sh" --help ;;
            "ddev")
                case "${2:-}" in
                    "update") exec bash "${SCRIPT_DIR}/scripts/update/wpupdate.sh" --help ;;
                    "mod")    exec bash "${SCRIPT_DIR}/scripts/mod/wpmod.sh" --help ;;
                    *)        exec bash "${SCRIPT_DIR}/scripts/install/wplocalinstall.sh" --help ;;
                esac
                ;;
        esac
    fi

    # Load all configuration
    log_info "Starting Webwerk WordPress Management Suite v2.0"
    load_environment
    load_license_keys
    validate_configuration "$command" "$@"
    load_helper_functions

    # Remove first argument (command/mode)
    shift

    # Execute command
    case "$command" in
        "install")
            # New syntax: webwerk install [full|minimal|ddev]
            local mode="${1:-full}"
            case "$mode" in
                "full" | "minimal" | "ddev") shift ;;
                *) mode="full" ;;  # default to full if no mode given
            esac
            log_info "Executing WordPress installation (mode: $mode)"
            run_install "$mode" "$@"
            ;;
        "full" | "minimal")
            # Legacy syntax: webwerk full install / webwerk minimal install
            local subcommand="${1:-}"
            if [[ "$subcommand" != "install" ]]; then
                log_error "Expected 'install' after '$command', got: ${subcommand:-nothing}"
                log_error "Usage: $0 install $command [OPTIONS]"
                exit 1
            fi
            shift  # Remove "install" from arguments

            log_info "Executing WordPress installation (mode: $command)"
            run_install "$command" "$@"
            ;;
        "ddev")
            # DDEV mode - expect "install" or "remove" as next argument
            local subcommand="${1:-}"
            case "$subcommand" in
                "install")
                    shift  # Remove "install" from arguments
                    log_info "Executing WordPress installation (mode: ddev)"
                    run_install "ddev" "$@"
                    ;;
                "remove")
                    shift  # Remove "remove" from arguments
                    log_info "Removing DDEV containers and configuration"

                    # Check if DDEV is configured
                    if [[ ! -f ".ddev/config.yaml" ]]; then
                        log_warning "No DDEV configuration found in current directory"
                        exit 0
                    fi

                    # Stop and remove DDEV containers
                    log_info "Stopping DDEV containers..."
                    ddev stop

                    log_info "Removing DDEV containers..."
                    ddev delete -O

                    log_success "DDEV containers removed successfully"
                    ;;
                "mod")
                    shift  # Remove "mod" from arguments
                    log_info "Running WordPress modification (mode: ddev)"

                    # Check if DDEV is running
                    if ! ddev status >/dev/null 2>&1; then
                        log_error "DDEV is not running. Please start DDEV first with 'ddev start'"
                        exit 1
                    fi

                    # Set DDEV-specific environment variables
                    export WP_CLI_PATH="ddev wp"
                    export WORDPRESS_BASE_DIR="."

                    if [[ -f "${SCRIPT_DIR}/scripts/mod/wpmod.sh" ]]; then
                        bash "${SCRIPT_DIR}/scripts/mod/wpmod.sh" "$@"
                    else
                        log_error "Modification script not found: ${SCRIPT_DIR}/scripts/mod/wpmod.sh"
                        exit 1
                    fi
                    ;;
                "update")
                    shift  # Remove "update" from arguments
                    log_info "Running WordPress update (mode: ddev)"

                    # Check if DDEV is running
                    if ! ddev status >/dev/null 2>&1; then
                        log_error "DDEV is not running. Please start DDEV first with 'ddev start'"
                        exit 1
                    fi

                    # Set DDEV-specific environment variables
                    export WP_CLI_PATH="ddev wp"
                    export WORDPRESS_BASE_DIR=""

                    if [[ -f "${SCRIPT_DIR}/scripts/update/wpupdate.sh" ]]; then
                        exec bash "${SCRIPT_DIR}/scripts/update/wpupdate.sh" --sites . "$@"
                    else
                        log_error "Update script not found: ${SCRIPT_DIR}/scripts/update/wpupdate.sh"
                        exit 1
                    fi
                    ;;
                *)
                    log_error "Expected 'install', 'remove', 'mod', or 'update' after 'ddev', got: ${subcommand:-nothing}"
                    log_error "Usage: $0 ddev [install|remove|mod|update] [OPTIONS]"
                    exit 1
                    ;;
            esac
            ;;
        "u" | "update")
            if [[ ! -f "${SCRIPT_DIR}/scripts/update/wpupdate.sh" ]]; then
                log_error "Update script not found: ${SCRIPT_DIR}/scripts/update/wpupdate.sh"
                exit 1
            fi
            local update_target="${1:-}"
            case "$update_target" in
                "core")
                    shift
                    log_info "Executing WordPress update (core only)"
                    exec bash "${SCRIPT_DIR}/scripts/update/wpupdate.sh" --skip-plugins "$@"
                    ;;
                "plugin")
                    shift
                    local plugin_name="${1:-}"
                    if [[ -z "$plugin_name" || "$plugin_name" == -* ]]; then
                        log_error "Usage: webwerk update plugin <name>[,name,...] [OPTIONS]"
                        exit 1
                    fi
                    shift
                    log_info "Executing WordPress update (plugin: $plugin_name)"
                    exec bash "${SCRIPT_DIR}/scripts/update/wpupdate.sh" --skip-core --only-plugins "$plugin_name" "$@"
                    ;;
                "plugins")
                    shift
                    log_info "Executing WordPress update (all plugins)"
                    exec bash "${SCRIPT_DIR}/scripts/update/wpupdate.sh" --skip-core "$@"
                    ;;
                "themes")
                    shift
                    log_info "Executing WordPress update (all themes)"
                    exec bash "${SCRIPT_DIR}/scripts/update/wpupdate.sh" --skip-core --skip-plugins --update-themes "$@"
                    ;;
                "theme")
                    shift
                    local theme_name="${1:-}"
                    if [[ -z "$theme_name" || "$theme_name" == -* ]]; then
                        log_error "Usage: webwerk update theme <name> [OPTIONS]"
                        exit 1
                    fi
                    shift
                    log_info "Executing WordPress update (theme: $theme_name)"
                    exec bash "${SCRIPT_DIR}/scripts/update/wpupdate.sh" --skip-core --skip-plugins --only-theme "$theme_name" "$@"
                    ;;
                ""|-*)
                    log_info "Executing WordPress update (core + plugins + themes)"
                    exec bash "${SCRIPT_DIR}/scripts/update/wpupdate.sh" --update-themes "$@"
                    ;;
                *)
                    log_error "Unknown update target: '$update_target'. Use: core, plugins, plugin <name>, themes, theme <name>, or omit for both."
                    exit 1
                    ;;
            esac
            ;;
        "mod")
            if [[ ! -f "${SCRIPT_DIR}/scripts/mod/wpmod.sh" ]]; then
                log_error "Modification script not found: ${SCRIPT_DIR}/scripts/mod/wpmod.sh"
                exit 1
            fi
            # Optional environment target: wp (default, local) or ddev
            case "${1:-}" in
                "ddev")
                    shift
                    log_info "Executing WordPress modification (mode: ddev)"
                    if ! ddev status >/dev/null 2>&1; then
                        log_error "DDEV is not running. Please start DDEV first with 'ddev start'"
                        exit 1
                    fi
                    export WP_CLI_PATH="ddev wp"
                    export WORDPRESS_BASE_DIR="."
                    ;;
                "wp")
                    shift
                    log_info "Executing WordPress modification (mode: wp)"
                    ;;
                *)
                    log_info "Executing WordPress modification (mode: wp)"
                    ;;
            esac
            exec bash "${SCRIPT_DIR}/scripts/mod/wpmod.sh" "$@"
            ;;
        *)
            log_error "Unknown command: $command"
            log_error "Use '$0 --help' for usage information"
            exit 1
            ;;
    esac
}

# Execute main function with all arguments
main "$@"
