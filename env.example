# Webwerk WordPress Management Suite Configuration
# Copy this file to .env and adjust values for your environment
# DO NOT commit .env to version control!

#===============================================================================
# DATABASE CONFIGURATION
#===============================================================================

# Database connection settings
DB_HOST=localhost
DB_USER=wordpress
DB_PASSWORD=your_secure_password_here

# Database name (auto-generated from directory name if not set)
# DB_NAME=

#===============================================================================
# WORDPRESS CONFIGURATION
#===============================================================================

# WP-CLI binary path
WP_CLI_PATH=/usr/local/bin/wp

# WordPress locale
WP_LOCALE=de_DE

# WordPress admin user
WP_ADMIN_USER=admin
WP_ADMIN_EMAIL=your@email.com

# WordPress admin password (auto-generated if not set)
# WP_ADMIN_PASSWORD=

# WordPress site title (auto-generated from directory if not set)
# WP_TITLE=

# WordPress URL (auto-generated from LOCAL_URL_BASE if not set)
# WP_URL=

# Debug mode default (true/false)
WP_DEBUG_DEFAULT=true

#===============================================================================
# GIT CONFIGURATION
#===============================================================================

# Git user/organization for repository cloning
GIT_USER=your_github_username

# Git host (default: github.com)
GIT_HOST=github.com

# Git protocol (https or ssh)
GIT_PROTOCOL=https

# Repository URL (auto-generated from GIT_USER if not set)
# REPO_URL=

#===============================================================================
# LOCAL DEVELOPMENT CONFIGURATION
#===============================================================================

# Base URL for local development
# WordPress URL will be: ${LOCAL_URL_BASE}/${directory_name}
LOCAL_URL_BASE=arbeit.local/repos

# Web server type: apache (LAMP) or nginx (LEMP)
# Set to nginx to generate nginx.conf instead of .htaccess
WEBSERVER_TYPE=nginx

# PHP-FPM socket path (only used when WEBSERVER_TYPE=nginx)
# PHP_FPM_SOCKET=unix:/run/php/php-fpm.sock

# Add security hardening to nginx.conf (deny xmlrpc, security headers, etc.)
# Set to true for production/public servers; default false = minimal local dev config
NGINX_PRODUCTION=false

# PHP upload limits (used for nginx client_max_body_size and .htaccess php_value)
PHP_UPLOAD_MAX_FILESIZE=64M
PHP_POST_MAX_SIZE=64M

# Web server user and group for file permissions
WEBSERVER_USER=www-data
WEBSERVER_GROUP=www-data

#===============================================================================
# SITE OPTIONS
#===============================================================================

# Disable search engine indexing for development (true/false)
DISABLE_SEARCH_INDEXING=true

# WordPress Multisite
# WP_MULTISITE=false
# WP_MULTISITE_SUBDOMAINS=false   # true = subdomain network, false = subdirectory

# Force SSL (true/false)
FORCE_SSL=false

# Output formatting
OUTPUT_LINE_WIDTH=60

#===============================================================================
# DDEV CONFIGURATION (for containerized development)
#===============================================================================

# DDEV automatically configures these when using --mode=ddev:
# - DB_HOST=db
# - DB_USER=db
# - DB_PASSWORD=db
# - DB_NAME=db
# - WP_CLI_PATH=ddev wp
# - WP_URL=${directory_name}.ddev.site

#===============================================================================
# ENVIRONMENT-SPECIFIC OVERRIDES
#===============================================================================

# Example: WSL2 specific settings
# if [[ "$(uname -a)" =~ WSL ]]; then
#     DB_HOST=127.0.0.1
#     LOCAL_URL_BASE=localhost/repos
# fi

# Example: Production overrides
